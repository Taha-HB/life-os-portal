# Application
NODE_ENV=development
APP_NAME=Life OS Portal
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# Server
PORT=5000
HOST=localhost

# MongoDB Atlas (Production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/life-os-portal?retryWrites=true&w=majority

# MongoDB Local (Development)
MONGODB_URI_LOCAL=mongodb://localhost:27017/life-os-portal

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Session
SESSION_SECRET=your-session-secret-min-32-characters
SESSION_MAX_AGE=604800000

# Security
CORS_ORIGIN=http://localhost:3000,https://yourdomain.vercel.app
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=10

# Email (SendGrid Free Tier)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@lifeosportal.com
EMAIL_FROM_NAME="Life OS Portal"

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=LifeOSPortalBot

# Prayer Times API (Aladhan API - Free)
PRAYER_API_URL=http://api.aladhan.com/v1
PRAYER_CALCULATION_METHOD=2

# Cloudinary (Free Tier)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=life-os-portal

# Redis (Optional - for production)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Backup
BACKUP_ENABLED=true
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * *

# Logging
LOG_LEVEL=info
LOG_PATH=./logs

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Maintenance
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System under maintenance. Please check back later."
